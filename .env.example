# RepubliAI – Environment Variables
# Copy this file to .env.local and fill in your values.

# ── AI Provider (swap-in point) ──────────────────────────────────────────────
# When you're ready to replace the mock engine in lib/repurpose.ts,
# uncomment and set one of the following:

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Optional: OpenAI-compatible endpoint (Azure, self-hosted, etc.) ───────────
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/
